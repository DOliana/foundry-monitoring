    "DCR_QUOTA_SNAPSHOT_IMMUTABLE_ID": "dcr-<immutable-id>",
    "DCR_DEPLOYMENT_CONFIG_IMMUTABLE_ID": "dcr-<immutable-id>",
    "DCR_TOKEN_USAGE_IMMUTABLE_ID": "dcr-<immutable-id>",
    "DCR_MODEL_CATALOG_IMMUTABLE_ID": "dcr-<immutable-id>",
