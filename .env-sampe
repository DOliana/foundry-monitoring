# Log Analytics workspace ID (Azure Portal → Log Analytics → Properties → Workspace ID)
WORKSPACE_ID=11111111-2222-3333-4444-555555555555

# Azure region of your Cognitive Services account
LOCATION=eastus

# Full resource ID of your Cognitive Services / Foundry account
RESOURCE_ID=/subscriptions/11111111-2222-3333-4444-555555555555/resourceGroups/my-rg/providers/Microsoft.CognitiveServices/accounts/my-foundry-account

# Azure Resource Manager API version
API_VERSION=2024-10-01
